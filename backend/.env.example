# Copia este fichero a backend/.env y rellena tu API key real. backend/.env está
# gitignored — nunca se versiona (ver .gitignore raíz, feat-21).

# API key de Alpha Vantage (https://www.alphavantage.co/support/#api-key) —
# necesaria para activar AlphaVantageProvider como proveedor alternativo de
# equity vía "PROVIDERS SET EQUITY ALPHAVANTAGE". Sin esta variable, sterminal
# sigue funcionando normalmente con yfinance como único proveedor de equity.
ALPHAVANTAGE_API_KEY=
